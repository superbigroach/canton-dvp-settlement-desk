{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "crossdesk-devnet-api", "region": "us-central1" }
      },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
