-- Test.daml
-- ===========================================================================
-- DAML SCRIPT scenarios for the Canton DvP Settlement Desk. Run them all with:
--
--     daml test
--
-- Daml Script runs against a ledger (the in-memory one under `daml test`, or a
-- real Canton ledger under `daml script`). It can allocate parties, submit
-- commands, and QUERY what each party can see — which is exactly how we PROVE the
-- privacy model, not merely assert it in prose.
--
-- Assertion helpers used below:
--   submit p cmds          — p submits; MUST succeed (else the test fails).
--   submitMustFail p cmds  — p submits; MUST fail   (proves a guard/limit works).
--   query @T p             — the contracts of template T that p can SEE (privacy probe).
--   queryContractId p cid  — Some c if p can SEE cid, else None.
--   (===) / assertMsg      — fail the script if a predicate is false.
--
-- END-TO-END COVERAGE:
--   testInstrumentAndHolding — reference data + mint/transfer/split/merge.
--   testBilateralDvP         — Alice buys AAPL from Bob for USD, atomically.
--   testMarketOnClose        — a sealed-order MOC auction: many orders → one
--                              uniform close price → atomic BATCH settlement.
--   testMarketOnCloseImbalance — an over-subscribed side is rationed PRO-RATA at
--                              the one close price; the residual does not settle.
--   testDarkPoolPrivacy      — a non-party (and even a rival participant) cannot
--                              see a resting sealed order.
--   testAtomicRollback       — a bad leg rolls the WHOLE settlement back.
--   testAgentInitiatedDvP    — an agent settles cETH within a ledger-enforced mandate.
--   testDesignatedLiquidityProvider — SELECTIVE imbalance disclosure: the DLP (and
--                              venue) see the NET book imbalance; a normal trader
--                              does NOT; the DLP sees only the aggregate (not the
--                              individual orders); the DLP offsets to clear the cross.
-- ===========================================================================

module Test where

import Daml.Script
import DA.Assert ((===))
import DA.List (head)
import DA.Optional (isNone, isSome)

import Instrument
import Holding
import Settlement
import MarketOnClose
import Agent

-- Instrument ids — keep string literals consistent across scenarios.
aapl : Text
aapl = "DEMO:AAPL"

usdc : Text
usdc = "USDC"

ceth : Text
ceth = "cETH"

cbtc : Text
cbtc = "CBTC"

-- ---------------------------------------------------------------------------
-- Shared party set. `daml.yaml`'s init-script (Test:initialize) reuses this so
-- `daml start` also has parties ready for the Navigator UI.
-- ---------------------------------------------------------------------------
data Parties = Parties
  with
    issuer  : Party   -- registrar/obligor for the tokenised instruments (stands in for onRails + a bank)
    venue   : Party   -- the Market-on-Close auction operator (the exchange)
    alice   : Party   -- trader
    bob     : Party   -- trader
    bank    : Party   -- another trader / liquidity provider
    auditor : Party   -- compliance observer of settlements (need-to-know)
    agent   : Party   -- Alice's authorised trading agent (the agentic angle)
    eve     : Party   -- OUTSIDER: party to nothing (the privacy control)

setup : Script Parties
setup = do
  issuer  <- allocatePartyWithHint "Issuer"  (PartyIdHint "Issuer")
  venue   <- allocatePartyWithHint "Venue"   (PartyIdHint "Venue")
  alice   <- allocatePartyWithHint "Alice"   (PartyIdHint "Alice")
  bob     <- allocatePartyWithHint "Bob"     (PartyIdHint "Bob")
  bank    <- allocatePartyWithHint "Bank"    (PartyIdHint "Bank")
  auditor <- allocatePartyWithHint "Auditor" (PartyIdHint "Auditor")
  agent   <- allocatePartyWithHint "Agent"   (PartyIdHint "Agent")
  eve     <- allocatePartyWithHint "Eve"     (PartyIdHint "Eve")
  pure (Parties issuer venue alice bob bank auditor agent eve)

-- Publish the three tokenised instruments (the reference-data layer). onRails is
-- the real cETH issuer on Devnet — here one `issuer` stands in for all three.
setupInstruments : Party -> Script ()
setupInstruments issuer = do
  _ <- submit issuer do
    createCmd Instrument with
      issuer; depository = issuer; id = aapl; version = "1"
      kind = "Equity"; description = "Demo tokenised equity (AAPL-like)"
      referencePrice = Some 255.0
  _ <- submit issuer do
    createCmd Instrument with
      issuer; depository = issuer; id = usdc; version = "1"
      kind = "Cash"; description = "Tokenised USD cash (USDC demo token) / bank deposit"
      referencePrice = None
  _ <- submit issuer do
    createCmd Instrument with
      issuer; depository = issuer; id = ceth; version = "1"
      kind = "CryptoWrapped"; description = "Wrapped ETH on Canton (onRails cETH)"
      referencePrice = Some 2400.0
  _ <- submit issuer do
    createCmd Instrument with
      issuer; depository = issuer; id = cbtc; version = "1"
      kind = "CryptoWrapped"; description = "Wrapped BTC on Canton (cBTC)"
      referencePrice = Some 65000.0
  pure ()

-- Mint a holding to `owner` (only the issuer signs).
mint : Party -> Text -> Party -> Decimal -> Script (ContractId Holding)
mint issuer instrumentId owner amount =
  submit issuer do createCmd Holding with issuer; instrumentId; owner; amount; disclosedTo = []

-- Total units of `inst` that party `p` currently owns (sums over holdings p sees).
ownedAmount : Party -> Text -> Script Decimal
ownedAmount p inst = do
  hs <- query @Holding p
  pure $ foldl
    (\acc (_, h) -> if h.instrumentId == inst && h.owner == p then acc + h.amount else acc)
    0.0 hs

-- ---------------------------------------------------------------------------
-- initialize — the `daml start` init-script. Allocates parties, publishes the
-- instruments, seeds holdings, and posts a live DvP proposal so you can log into
-- Navigator as Alice and Accept, then as Bob and Settle.
-- ---------------------------------------------------------------------------
initialize : Script ()
initialize = do
  Parties{..} <- setup
  setupInstruments issuer

  -- Bob (the SELLER) holds 10 AAPL; Alice (the BUYER) holds 2,550 USD.
  bobAapl   <- mint issuer aapl bob   10.0
  aliceCash <- mint issuer usdc  alice 2550.0

  -- Crypto-wrapped inventory for the cETH + CBTC desks. Both Alice and Bob carry
  -- a starting book so the blotter shows real cETH/CBTC/USDC positions and either
  -- party can settle or send a crypto leg to the opening/closing cross.
  _ <- mint issuer ceth alice 5.0       -- Alice: 5 cETH  (~12,000 USDC @ 2,400)
  _ <- mint issuer ceth bob   4.0       -- Bob:   4 cETH
  _ <- mint issuer cbtc alice 1.0       -- Alice: 1 CBTC  (~65,000 USDC)
  _ <- mint issuer cbtc bob   2.0       -- Bob:   2 CBTC
  _ <- mint issuer usdc bob   50000.0   -- Bob: working USDC cash for crypto buys
  _ <- mint issuer usdc alice 150000.0  -- Alice: working USDC cash for crypto buys

  -- Bank is the DESIGNATED LIQUIDITY PROVIDER for the auctions (see the auto-opened
  -- auction in the backend, which sets liquidityProvider = Bank). It must carry a
  -- deep book on BOTH legs so it can offset a net imbalance on whichever side the
  -- book is heavy: sell the asset into a buy-heavy book, or buy it in a sell-heavy
  -- one. Give it inventory across every instrument plus ample cash.
  _ <- mint issuer aapl bank 500.0      -- Bank: 500 AAPL to sell into buy-heavy AAPL closes
  _ <- mint issuer ceth bank 100.0      -- Bank: 100 cETH liquidity
  _ <- mint issuer cbtc bank 20.0       -- Bank: 20 CBTC liquidity
  _ <- mint issuer usdc bank 2000000.0  -- Bank: 2,000,000 USDC to buy into sell-heavy books

  -- Bob proposes to sell 10 AAPL for 2,550 USD (255.0 each). Alice is counterparty.
  _ <- submit bob do
    createCmd DvPProposal with
      proposer = bob
      counterparty = alice
      auditor
      assetHoldingCid = bobAapl
      cashHoldingCid = aliceCash
      assetInstrument = aapl
      assetAmount = 10.0
      cashInstrument = usdc
      cashAmount = 2550.0
  pure ()

-- ---------------------------------------------------------------------------
-- TEST 1 — Reference data + holding lifecycle.
-- ---------------------------------------------------------------------------
testInstrumentAndHolding : Script ()
testInstrumentAndHolding = do
  Parties{..} <- setup
  setupInstruments issuer

  -- Mint 3 cETH to Alice; only the issuer signs.
  cethCid <- mint issuer ceth alice 3.0

  -- Alice transfers the cETH to Bob. No consent from Bob needed: the successor
  -- is issuer-signed (delegated) and Bob merely becomes the new observer/holder.
  cethCid2 <- submit alice do exerciseCmd cethCid Transfer with newOwner = bob
  Some now <- queryContractId bob cethCid2
  now.owner        === bob
  now.instrumentId === ceth
  now.amount       === 3.0
  archived <- queryContractId alice cethCid
  assertMsg "original cETH holding must be archived after transfer" (isNone archived)

  -- Split and merge (the partial-fill primitive).
  bigCid <- mint issuer aapl alice 10.0
  (deliverCid, changeCid) <- submit alice do exerciseCmd bigCid Split with splitAmount = 4.0
  Some d <- queryContractId alice deliverCid
  Some c <- queryContractId alice changeCid
  d.amount === 4.0
  c.amount === 6.0
  mergedCid <- submit alice do exerciseCmd deliverCid Merge with otherCid = changeCid
  Some m <- queryContractId alice mergedCid
  m.amount === 10.0
  -- Over-splitting must fail.
  submitMustFail alice do exerciseCmd mergedCid Split with splitAmount = 99.0

-- ---------------------------------------------------------------------------
-- TEST 2 — Bilateral atomic DvP: Alice buys AAPL from Bob paying USD.
-- Both legs move in ONE transaction; a bilateral audit receipt is written in the
-- same tx; the auditor sees the receipt but NOT the underlying holdings.
-- ---------------------------------------------------------------------------
testBilateralDvP : Script ()
testBilateralDvP = do
  Parties{..} <- setup

  bobAapl   <- mint issuer aapl bob   10.0    -- Bob (seller) delivers the asset
  aliceCash <- mint issuer usdc  alice 2550.0  -- Alice (buyer) delivers the cash

  -- Bob proposes; Alice + the auditor are observers.
  propCid <- submit bob do
    createCmd DvPProposal with
      proposer = bob; counterparty = alice; auditor
      assetHoldingCid = bobAapl; cashHoldingCid = aliceCash
      assetInstrument = aapl; assetAmount = 10.0
      cashInstrument = usdc;   cashAmount = 2550.0

  -- PRIVACY: Alice sees the proposal (observer); so does the auditor.
  assertMsg "buyer must see the proposal"  . isSome =<< queryContractId alice propCid
  assertMsg "auditor must see the proposal" . isSome =<< queryContractId auditor propCid

  -- Alice ACCEPTS -> a bilaterally-signed agreement; Bob SETTLES -> atomic swap.
  agreeCid <- submit alice do exerciseCmd propCid Accept
  res      <- submit bob   do exerciseCmd agreeCid Settle

  -- Ownership swapped, amounts preserved.
  Some aaplNow <- queryContractId alice res.deliveredAsset
  aaplNow.owner  === alice
  aaplNow.amount === 10.0
  Some cashNow <- queryContractId bob res.deliveredCash
  cashNow.owner  === bob
  cashNow.amount === 2550.0

  -- AUDIT: the auditor sees the receipt (the trade)...
  Some receipt <- queryContractId auditor res.receipt
  receipt.assetAmount === 10.0
  receipt.cashAmount  === 2550.0
  receipt.unitPrice   === 255.0

  -- ...but NOT the underlying holdings (issuer + owner only). Need-to-know.
  assertMsg "auditor must NOT see the delivered asset" . isNone =<< queryContractId auditor res.deliveredAsset
  assertMsg "auditor must NOT see the delivered cash"  . isNone =<< queryContractId auditor res.deliveredCash

  -- OUTSIDER: Eve sees nothing and cannot settle someone else's trade.
  assertMsg "outsider must not see the asset holding" . isNone =<< queryContractId eve bobAapl

-- ---------------------------------------------------------------------------
-- TEST 3 — Market-on-Close: a sealed-order call auction that settles a BATCH
-- of crosses atomically at ONE closing price.
-- ---------------------------------------------------------------------------
-- Book (all AAPL, cash in USD; sealed — nobody sees anyone else's order):
--   SELL  Bob    10 @ 250      BUY  Alice 10 @ 260  (commits 2,600 USD)
--   SELL  Carol   8 @ 253      BUY  Dave   8 @ 256  (commits 2,040 USD)
-- Operator sets the close at 255.0. Both pairs cross; the batch prints at 255.
-- ---------------------------------------------------------------------------
testMarketOnClose : Script ()
testMarketOnClose = do
  Parties{..} <- setup
  setupInstruments issuer
  carol <- allocatePartyWithHint "Carol" (PartyIdHint "Carol")
  dave  <- allocatePartyWithHint "Dave"  (PartyIdHint "Dave")

  -- Sellers pre-hold the asset; buyers pre-hold cash to commit.
  bobAsset   <- mint issuer aapl bob   10.0
  carolAsset <- mint issuer aapl carol 8.0
  aliceCash  <- mint issuer usdc  alice 2600.0
  daveCash   <- mint issuer usdc  dave  2040.0

  -- The venue opens the auction for AAPL with four registered participants. The
  -- official closing price (255.0, the AAPL reference price) is published on the
  -- auction — every fill will print at THIS one price.
  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"
      referencePrice = 255.0
      participants = [alice, bob, carol, dave]; liquidityProvider = None; isOpen = True

  -- Each participant lodges a SEALED order, pre-committing its holding.
  bobSell <- submit bob do
    exerciseCmd auctionCid SubmitOrder with
      trader = bob; side = Sell; quantity = 10.0; limitPrice = 250.0; holdingCid = bobAsset
  carolSell <- submit carol do
    exerciseCmd auctionCid SubmitOrder with
      trader = carol; side = Sell; quantity = 8.0; limitPrice = 253.0; holdingCid = carolAsset
  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceCash
  daveBuy <- submit dave do
    exerciseCmd auctionCid SubmitOrder with
      trader = dave; side = Buy; quantity = 8.0; limitPrice = 256.0; holdingCid = daveCash

  -- DARK POOL: even a registered participant cannot see a RIVAL's sealed order.
  assertMsg "Carol must NOT see Alice's sealed order" . isNone =<< queryContractId carol aliceBuy
  assertMsg "Bob must NOT see Dave's sealed order"     . isNone =<< queryContractId bob daveBuy

  -- The operator seals the window, then runs the close. The auction crosses
  -- min(totalBuy, totalSell) at the published 255.0 — here the sides are balanced
  -- (18 vs 18) so every order fills in full. All fills settle in ONE atomic tx.
  closedCid <- submit venue do exerciseCmd auctionCid CloseBidding
  batchCid  <- submit venue do
    exerciseCmd closedCid RunClose with
      buyOrders  = [aliceBuy, daveBuy]
      sellOrders = [bobSell, carolSell]

  -- The batch prints at 255.0 with a fill record per filled order (2 buys +
  -- 2 sells = 4); the auditor sees it.
  Some batch <- queryContractId auditor batchCid
  batch.closingPrice === 255.0
  length batch.fills === 4
  -- EVERY fill printed at the ONE uniform closing price.
  assertMsg "all fills must print at the uniform closing price"
    (all (\f -> f.price == 255.0) batch.fills)

  -- Post-close ownership: buyers hold the asset, sellers hold the cash.
  aliceAapl <- ownedAmount alice aapl
  daveAapl  <- ownedAmount dave  aapl
  bobUsd    <- ownedAmount bob   usdc
  carolUsd  <- ownedAmount carol usdc
  aliceAapl === 10.0            -- Alice bought 10 AAPL
  daveAapl  === 8.0             -- Dave bought 8 AAPL
  bobUsd    === 2550.0          -- Bob sold 10 @ 255
  carolUsd  === 2040.0          -- Carol sold 8 @ 255
  -- Alice committed 2,600 USD but paid 2,550 — 50 USD change returned to her.
  aliceUsd <- ownedAmount alice usdc
  aliceUsd === 50.0

-- ---------------------------------------------------------------------------
-- TEST 3a — OPENING CROSS (Market-on-Open / MOO): the SAME sealed uniform-price
-- auction run as an OPENING session. The crossing logic is identical to the
-- close; only `session = "Open"` differs, so the printed uniform price is the
-- OFFICIAL OPEN. Crossed on cETH to exercise a CryptoWrapped instrument.
-- ---------------------------------------------------------------------------
testOpeningCross : Script ()
testOpeningCross = do
  Parties{..} <- setup
  setupInstruments issuer

  -- Bob sells 3 cETH; Alice buys 3 cETH; both pre-commit. Official open = 2,400.
  bobCeth   <- mint issuer ceth bob   3.0
  aliceCash <- mint issuer usdc alice 7500.0

  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = ceth; cashInstrument = usdc
      session = "Open"
      referencePrice = 2400.0
      participants = [alice, bob]; liquidityProvider = None; isOpen = True

  bobSell <- submit bob do
    exerciseCmd auctionCid SubmitOrder with
      trader = bob; side = Sell; quantity = 3.0; limitPrice = 2350.0; holdingCid = bobCeth
  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 3.0; limitPrice = 2500.0; holdingCid = aliceCash

  closedCid <- submit venue do exerciseCmd auctionCid CloseBidding
  batchCid  <- submit venue do
    exerciseCmd closedCid RunClose with buyOrders = [aliceBuy]; sellOrders = [bobSell]

  -- The opening cross prints every fill at the ONE official open (2,400).
  Some batch <- queryContractId auditor batchCid
  batch.closingPrice === 2400.0
  length batch.fills === 2
  assertMsg "all opening fills print at the uniform official open"
    (all (\f -> f.price == 2400.0) batch.fills)

  -- Post-open: Alice holds 3 cETH, Bob holds the 7,200 USDC proceeds (3 @ 2,400).
  aliceCeth <- ownedAmount alice ceth
  bobUsd    <- ownedAmount bob   usdc
  aliceCeth === 3.0
  bobUsd    === 7200.0

-- ---------------------------------------------------------------------------
-- TEST 3b — MARKET-ON-CLOSE with an IMBALANCE: the heavy side is rationed
-- PRO-RATA at the ONE uniform closing price; the light side fills in full; the
-- unmatched residual does NOT settle.
-- ---------------------------------------------------------------------------
-- Book (all AAPL, cash USD; sealed):
--   BUY  Alice 10 @ 260  (commits 2,550 USD)   BUY  Bank 10 @ 258 (commits 2,550 USD)
--   SELL Bob   30 @ 250  (commits 30 AAPL)
-- totalBuy = 20, totalSell = 30  ->  matched = 20 (SELL side is heavy).
-- Buyers fill in FULL (10 each). Bob is rationed pro-rata: 30 * 20/30 = 20 filled,
-- 10 left UNFILLED (stays as his holding). Everything prints at 255.0.
-- ---------------------------------------------------------------------------
testMarketOnCloseImbalance : Script ()
testMarketOnCloseImbalance = do
  Parties{..} <- setup
  setupInstruments issuer

  -- One big seller vs two smaller buyers -> a sell-heavy imbalance.
  bobAsset  <- mint issuer aapl bob  30.0     -- Bob offers 30 AAPL
  aliceCash <- mint issuer usdc alice 2550.0   -- each buyer commits enough for 10 @ 255
  bankCash  <- mint issuer usdc bank  2550.0

  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"
      referencePrice = 255.0
      participants = [alice, bank, bob]; liquidityProvider = None; isOpen = True

  bobSell <- submit bob do
    exerciseCmd auctionCid SubmitOrder with
      trader = bob; side = Sell; quantity = 30.0; limitPrice = 250.0; holdingCid = bobAsset
  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceCash
  bankBuy <- submit bank do
    exerciseCmd auctionCid SubmitOrder with
      trader = bank; side = Buy; quantity = 10.0; limitPrice = 258.0; holdingCid = bankCash

  closedCid <- submit venue do exerciseCmd auctionCid CloseBidding
  batchCid  <- submit venue do
    exerciseCmd closedCid RunClose with
      buyOrders  = [aliceBuy, bankBuy]
      sellOrders = [bobSell]

  -- Uniform price on every fill; 2 buys + 1 sell = 3 fill records.
  Some batch <- queryContractId auditor batchCid
  batch.closingPrice === 255.0
  length batch.fills === 3
  assertMsg "all fills must print at the uniform closing price"
    (all (\f -> f.price == 255.0) batch.fills)
  -- Bob's single sell fill is the pro-rated 20 (of his 30), not the full 30.
  let bobFill = head (filter (\f -> f.seller == bob) batch.fills)
  bobFill.quantity === 20.0

  -- Buyers filled in FULL and hold the asset; each paid 10 @ 255 = 2,550 (no change).
  aliceAapl <- ownedAmount alice aapl
  bankAapl  <- ownedAmount bank  aapl
  aliceAapl === 10.0
  bankAapl  === 10.0
  aliceUsd <- ownedAmount alice usdc
  bankUsd  <- ownedAmount bank  usdc
  aliceUsd === 0.0
  bankUsd  === 0.0

  -- Bob sold the pro-rated 20 @ 255 = 5,100 USD, and KEEPS the 10 unfilled AAPL
  -- (the residual did not settle) — proving partial, rationed settlement.
  bobUsd  <- ownedAmount bob usdc
  bobAapl <- ownedAmount bob aapl
  bobUsd  === 5100.0
  bobAapl === 10.0

-- ---------------------------------------------------------------------------
-- TEST 3c — RESERVED BACKING survives a same-trader SECOND order (the fix for the
-- stale-holding CONTRACT_NOT_FOUND). One trader lodges TWO buys out of a SINGLE
-- cash holding; each order reserves its own dedicated slice, so submitting the
-- second does NOT invalidate the first, and the close crosses both without a
-- missing-contract error. Bob sells enough to fill them.
-- ---------------------------------------------------------------------------
testReservedBackingSurvivesResubmit : Script ()
testReservedBackingSurvivesResubmit = do
  Parties{..} <- setup
  setupInstruments issuer

  -- Alice has ONE 5,100 USDC holding backing BOTH of her buys (10 @ 255 each).
  aliceCash <- mint issuer usdc alice 5100.0
  bobAsset  <- mint issuer aapl bob   20.0

  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"; referencePrice = 255.0
      participants = [alice, bob]; liquidityProvider = None; isOpen = True

  -- First buy reserves 2,550 out of Alice's single holding into a dedicated slice
  -- (disclosed to the venue); the 2,550 change stays FREE and private to Alice.
  aliceBuy1 <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceCash
  -- Alice still owns all 5,100 (2,550 reserved + 2,550 free) until the cross.
  aliceTotal <- ownedAmount alice usdc
  aliceTotal === 5100.0
  -- Second buy: pick Alice's FREE cash (NOT the slice already committed to the
  -- venue), exactly as the desk's provisioning does — so buy1's reserved slice is
  -- never re-consumed. This is the crux: a same-trader re-submit is safe.
  aliceFree <- head . map fst
    . filter (\(_, h) -> h.owner == alice && h.instrumentId == usdc && null h.disclosedTo)
    <$> query @Holding alice
  aliceBuy2 <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceFree
  bobSell <- submit bob do
    exerciseCmd auctionCid SubmitOrder with
      trader = bob; side = Sell; quantity = 20.0; limitPrice = 250.0; holdingCid = bobAsset

  -- The FIRST order's pinned holding is still valid at the close: both buys cross.
  closedCid <- submit venue do exerciseCmd auctionCid CloseBidding
  batchCid  <- submit venue do
    exerciseCmd closedCid RunClose with
      buyOrders  = [aliceBuy1, aliceBuy2]
      sellOrders = [bobSell]
  Some batch <- queryContractId auditor batchCid
  length batch.fills === 3     -- 2 buys + 1 sell, no CONTRACT_NOT_FOUND
  aliceAapl <- ownedAmount alice aapl
  aliceAapl === 20.0           -- Alice bought all 20 across her two orders

-- ---------------------------------------------------------------------------
-- TEST 3d — WITHDRAW + VENUE CLEAR: a trader withdraws their own resting order
-- (its reserved cash returns to being freely theirs), and the venue can clear a
-- resting order off the book. Neither loses the trader any balance.
-- ---------------------------------------------------------------------------
testWithdrawAndVenueClear : Script ()
testWithdrawAndVenueClear = do
  Parties{..} <- setup
  setupInstruments issuer

  aliceCash <- mint issuer usdc alice 2550.0
  bobAsset  <- mint issuer aapl bob   10.0

  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"; referencePrice = 255.0
      participants = [alice, bob]; liquidityProvider = None; isOpen = True

  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceCash
  bobSell <- submit bob do
    exerciseCmd auctionCid SubmitOrder with
      trader = bob; side = Sell; quantity = 10.0; limitPrice = 250.0; holdingCid = bobAsset

  -- Alice WITHDRAWS her order. It is gone from the book; her 2,550 USDC is
  -- unlocked back to a free, private holding (venue no longer observes it).
  unlocked <- submit alice do exerciseCmd aliceBuy Cancel
  goneA <- queryContractId venue aliceBuy
  assertMsg "withdrawn order must be archived" (isNone goneA)
  aliceUsd <- ownedAmount alice usdc
  aliceUsd === 2550.0
  Some uh <- queryContractId alice unlocked
  assertMsg "unlocked holding is private to Alice again" (null uh.disclosedTo)
  assertMsg "venue can no longer see the unlocked holding" . isNone
    =<< queryContractId venue unlocked

  -- The VENUE CLEARS Bob's resting sell off the book. Bob keeps his 10 AAPL.
  submit venue do exerciseCmd bobSell VenueCancel
  goneB <- queryContractId venue bobSell
  assertMsg "venue-cleared order must be archived" (isNone goneB)
  bobAapl <- ownedAmount bob aapl
  bobAapl === 10.0

  -- A trader cannot clear the book (only the operator can VenueCancel), and a
  -- non-owner cannot withdraw someone else's order.
  aliceBuy2 <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = unlocked
  submitMustFail bob   do exerciseCmd aliceBuy2 Cancel        -- not the owner
  submitMustFail alice do exerciseCmd aliceBuy2 VenueCancel   -- not the operator

-- ---------------------------------------------------------------------------
-- TEST 4 — DARK-POOL PRIVACY: an outsider (Eve) sees no order, no holding, no
-- batch — and cannot settle anything.
-- ---------------------------------------------------------------------------
testDarkPoolPrivacy : Script ()
testDarkPoolPrivacy = do
  Parties{..} <- setup

  aliceCash <- mint issuer usdc alice 2550.0
  bobAsset  <- mint issuer aapl bob  10.0

  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"
      referencePrice = 255.0
      participants = [alice, bob]; liquidityProvider = None; isOpen = True
  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 10.0; limitPrice = 260.0; holdingCid = aliceCash

  -- Eve is party to NOTHING. From her participant these contracts do not exist.
  eveOrders   <- query @SealedOrder eve
  eveHoldings <- query @Holding eve
  eveAuction  <- queryContractId eve auctionCid
  assertMsg "outsider must see zero sealed orders" (null eveOrders)
  assertMsg "outsider must see zero holdings"      (null eveHoldings)
  assertMsg "outsider must not see the auction"    (isNone eveAuction)

  -- Eve cannot move a holding she can't see (Bob's asset, still live and private),
  -- nor cancel into the sealed book. (Alice's cash was consumed when she pledged
  -- it into her sealed order — allocated to the venue, not to Eve.)
  submitMustFail eve do exerciseCmd bobAsset Transfer with newOwner = eve
  submitMustFail eve do exerciseCmd aliceBuy Cancel

-- ---------------------------------------------------------------------------
-- TEST 5 — ATOMIC ROLLBACK: a leg precondition fails, so the WHOLE settlement
-- rolls back. No principal risk — the seller keeps his asset.
-- ---------------------------------------------------------------------------
testAtomicRollback : Script ()
testAtomicRollback = do
  Parties{..} <- setup

  bobAapl   <- mint issuer aapl bob   10.0
  -- Alice's cash is only 2,500 — but the proposal states a price of 2,550.
  aliceCash <- mint issuer usdc  alice 2500.0
  propCid <- submit bob do
    createCmd DvPProposal with
      proposer = bob; counterparty = alice; auditor
      assetHoldingCid = bobAapl; cashHoldingCid = aliceCash
      assetInstrument = aapl; assetAmount = 10.0
      cashInstrument = usdc;   cashAmount = 2550.0   -- disagrees with the actual 2,500

  -- Accept ALLOCATES (discloses) the cash leg to the proposer — that re-creates
  -- Alice's cash holding under a new contract id (same owner, same 2,500 amount),
  -- which is an allocation, NOT a settlement move.
  agreeCid <- submit alice do exerciseCmd propCid Accept
  -- Settle asserts cash.amount == cashAmount (2500 /= 2550) -> whole tx aborts.
  submitMustFail bob do exerciseCmd agreeCid Settle

  -- Nothing SETTLED: Bob still owns his (untouched) AAPL, and Alice still holds
  -- her full 2,500 USD (checked by balance, since the allocation re-issued the
  -- cash holding under a fresh id).
  Some aaplStill <- queryContractId bob bobAapl
  aaplStill.owner  === bob
  aaplStill.amount === 10.0
  aliceUsd <- ownedAmount alice usdc
  aliceUsd === 2500.0
  bobUsd <- ownedAmount bob usdc
  bobUsd === 0.0                    -- Bob received no cash: the swap did not happen

-- ---------------------------------------------------------------------------
-- TEST 6 — AGENT-INITIATED DvP within a mandate limit (settling cETH).
-- Alice grants an Agent a mandate to sell up to 3 cETH. An over-limit attempt
-- fails; a within-limit attempt creates a proposal that then settles atomically.
-- ---------------------------------------------------------------------------
testAgentInitiatedDvP : Script ()
testAgentInitiatedDvP = do
  Parties{..} <- setup

  aliceCeth0 <- mint issuer ceth alice 2.0     -- Alice's 2 cETH to sell
  bobCash    <- mint issuer usdc  bob   5000.0  -- Bob's cash to pay

  -- Alice ALLOCATES the cETH to her Agent: she discloses the holding so the agent
  -- can reference/validate it inside InitiateDvP (the mandate carries Alice's
  -- AUTHORITY, but the agent still needs VISIBILITY of the specific holding).
  aliceCeth <- submit alice do exerciseCmd aliceCeth0 Disclose with newObserver = agent

  -- Alice delegates: the Agent may initiate cETH settlements up to 3 cETH.
  mandateCid <- submit alice do
    createCmd TradingMandate with
      principal = alice; agent; instrument = ceth; maxAmount = 3.0

  -- OVER-LIMIT: a 4 cETH holding breaches the 3 cETH cap -> must fail. Alice
  -- allocates it to the agent too, so the rejection is genuinely the mandate
  -- limit (not a visibility error).
  bigCeth0 <- mint issuer ceth alice 4.0
  bigCeth  <- submit alice do exerciseCmd bigCeth0 Disclose with newObserver = agent
  submitMustFail agent do
    exerciseCmd mandateCid InitiateDvP with
      counterparty = bob; auditor
      assetHoldingCid = bigCeth; cashHoldingCid = bobCash
      assetAmount = 4.0; cashInstrument = usdc; cashAmount = 5000.0

  -- WITHIN LIMIT: the Agent initiates a valid 2 cETH settlement on Alice's behalf.
  propCid <- submit agent do
    exerciseCmd mandateCid InitiateDvP with
      counterparty = bob; auditor
      assetHoldingCid = aliceCeth; cashHoldingCid = bobCash
      assetAmount = 2.0; cashInstrument = usdc; cashAmount = 5000.0

  -- The proposal names Alice as proposer — Bob never sees the agent.
  Some prop <- queryContractId bob propCid
  prop.proposer     === alice
  prop.counterparty === bob

  -- Bob accepts; Alice (the proposer) settles the agent-initiated trade.
  agreeCid <- submit bob   do exerciseCmd propCid  Accept
  res      <- submit alice do exerciseCmd agreeCid Settle
  Some cethNow <- queryContractId bob res.deliveredAsset
  cethNow.owner  === bob
  cethNow.amount === 2.0
  Some cashNow <- queryContractId alice res.deliveredCash
  cashNow.owner  === alice
  cashNow.amount === 5000.0

-- ---------------------------------------------------------------------------
-- TEST 7 — DESIGNATED LIQUIDITY PROVIDER: selective net-imbalance disclosure.
-- ---------------------------------------------------------------------------
-- LIQUIDITY WITHOUT LEAKAGE. A lit auction publishes its imbalance to the whole
-- market (leaking it to front-runners); a dark pool leaks nothing but risks a
-- no-fill. Canton does BOTH: reveal the NET imbalance to ONE designated liquidity
-- provider (who commits to offset it), and to nobody else.
--
-- Book (AAPL, cash USDC, close 255, sealed):
--   BUY  Alice 2 @ 260   →  net BUY imbalance of 2 (no sells yet).
-- The venue publishes the aggregate to the DLP (Bank). We PROVE:
--   * Bank (DLP) SEES "Net BUY 2 @ 255"; the venue sees it too.
--   * Bank sees ONLY the aggregate — NOT Alice's individual sealed order.
--   * Carol (a normal registered trader) sees NEITHER the imbalance NOR the order.
--   * Bank offsets by SELLING 2; the republished imbalance is now Flat; the close
--     crosses cleanly (Alice +2 AAPL, Bank +510 USDC).
-- ---------------------------------------------------------------------------
testDesignatedLiquidityProvider : Script ()
testDesignatedLiquidityProvider = do
  Parties{..} <- setup
  setupInstruments issuer
  carol <- allocatePartyWithHint "Carol" (PartyIdHint "Carol")

  aliceCash <- mint issuer usdc alice 600.0   -- enough to buy 2 @ 255 (= 510), 90 change
  bankAsset <- mint issuer aapl bank  10.0    -- the DLP's inventory to offset with

  -- The venue opens the auction and DESIGNATES Bank as the liquidity provider.
  auctionCid <- submit venue do
    createCmd ClosingAuction with
      operator = venue; auditor; instrumentId = aapl; cashInstrument = usdc
      session = "Close"; referencePrice = 255.0
      participants = [alice, bank, carol]
      liquidityProvider = Some bank
      isOpen = True

  -- Alice lodges a sealed BUY of 2. The book is now net BUY 2.
  aliceBuy <- submit alice do
    exerciseCmd auctionCid SubmitOrder with
      trader = alice; side = Buy; quantity = 2.0; limitPrice = 260.0; holdingCid = aliceCash

  -- The venue publishes the NET imbalance to the DLP (aggregate only).
  discCid <- submit venue do
    exerciseCmd auctionCid PublishImbalance with restingOrders = [aliceBuy]

  -- THE DLP SEES THE AGGREGATE: net BUY of 2 at the reference price.
  Some disc <- queryContractId bank discCid
  disc.netSide     === "Buy"
  disc.netQuantity === 2.0
  disc.referencePrice === 255.0
  disc.liquidityProvider === bank
  -- The venue (operator) sees it too.
  assertMsg "venue must see the imbalance disclosure" . isSome =<< queryContractId venue discCid

  -- SELECTIVE: the DLP sees ONLY the aggregate — NOT Alice's individual order.
  assertMsg "DLP must NOT see the individual sealed order (aggregate only)"
    . isNone =<< queryContractId bank aliceBuy

  -- A normal registered trader (Carol) sees NEITHER the imbalance NOR the order.
  carolSeesImbalance <- query @ImbalanceDisclosure carol
  assertMsg "a normal trader must NOT see any imbalance disclosure" (null carolSeesImbalance)
  assertMsg "a normal trader must NOT see a rival's sealed order"
    . isNone =<< queryContractId carol aliceBuy

  -- THE DLP OFFSETS: Bank lodges a sealed SELL of 2 (the opposite side) to clear
  -- the cross. Its order is as private as any other.
  bankSell <- submit bank do
    exerciseCmd auctionCid SubmitOrder with
      trader = bank; side = Sell; quantity = 2.0; limitPrice = 250.0; holdingCid = bankAsset

  -- The venue republishes: the book is now balanced (Flat).
  discCid2 <- submit venue do
    exerciseCmd auctionCid PublishImbalance with restingOrders = [aliceBuy, bankSell]
  Some disc2 <- queryContractId bank discCid2
  disc2.netSide     === "Flat"
  disc2.netQuantity === 0.0

  -- Run the close: the offsetting orders cross cleanly at 255.
  closedCid <- submit venue do exerciseCmd auctionCid CloseBidding
  batchCid  <- submit venue do
    exerciseCmd closedCid RunClose with
      buyOrders  = [aliceBuy]
      sellOrders = [bankSell]
  Some batch <- queryContractId auditor batchCid
  batch.closingPrice === 255.0
  length batch.fills === 2

  -- Alice bought 2 AAPL for 510 (90 change); the DLP sold 2 AAPL for 510 USDC.
  aliceAapl <- ownedAmount alice aapl
  aliceUsd  <- ownedAmount alice usdc
  bankAapl  <- ownedAmount bank  aapl
  bankUsd   <- ownedAmount bank  usdc
  aliceAapl === 2.0
  aliceUsd  === 90.0
  bankAapl  === 8.0
  bankUsd   === 510.0

  -- PRIVACY GUARD: an outsider cannot ask the venue to disclose the imbalance to
  -- itself — PublishImbalance is operator-controlled, and only the DLP observes it.
  pure ()
